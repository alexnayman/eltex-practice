mkdir -p D1/D2/D2
touch D1/D2/file.txt
echo "Hello" > D1/D2/file.txt
ln -s D1/D2/file.txt D1/D2/D3/slink
ln D1/D2/file.txt D1/D2/D3/hlink
ls D1/D2/D3
mv D1/D2/file.txt D1/
cat D1/D2/D3/slink
cat D1/D2/D3/hlink
rm -r D1/D2
find / -type f -size +20M 2>/dev/null > ~/${USER}_part3_gt20M.log
du -h $(cat ${USER}_part3_gt50M.log)
find ~ -type f -mtime -1
which find
file /usr/bin/find
file /boot/initrd.img*
